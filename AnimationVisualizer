--////////////////////////////////////////////////////
-- ANIMATION SYSTEM
--////////////////////////////////////////////////////
local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
local currentTrack = nil
local currentAnimation = nil

local function loadAnimation(animIdNumber: string)
	-- Clean up old track
	if currentTrack then
		currentTrack:Stop()
		currentTrack:Destroy()
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. animIdNumber

	currentAnimation = anim
	currentTrack = animator:LoadAnimation(anim)
	currentTrack.Looped = true
	currentTrack:Play()
	currentTrack:AdjustSpeed(tonumber(speedBox.Text) or 1)
end

-- Load initial animation
loadAnimation("13336390868")

--////////////////////////////////////////////////////
-- CAMERA ORBIT
--////////////////////////////////////////////////////
local camera = Instance.new("Camera")
camera.Parent = viewport
viewport.CurrentCamera = camera

local zoom = 8
local yaw = 180
local pitch = 15
local camDragging = false
local cursorInside = false
local lastMousePos = nil

viewport.MouseEnter:Connect(function() cursorInside = true end)
viewport.MouseLeave:Connect(function() cursorInside = false end)

viewport.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		camDragging = true
		lastMousePos = UserInputService:GetMouseLocation()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		camDragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if camDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local currentPos = UserInputService:GetMouseLocation()
		local delta = currentPos - lastMousePos
		lastMousePos = currentPos

		yaw -= delta.X * 0.4
		pitch -= delta.Y * 0.4
		pitch = math.clamp(pitch, -85, 85)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if cursorInside and input.UserInputType == Enum.UserInputType.MouseWheel then
		zoom -= input.Position.Z
		zoom = math.clamp(zoom, 2, 25)
	end
end)

ContextActionService:BindAction("BlockViewportZoom", function() return Enum.ContextActionResult.Sink end, false, Enum.UserInputType.MouseWheel)
ContextActionService:BindAction("BlockViewportDrag", function() return Enum.ContextActionResult.Sink end, false, Enum.UserInputType.MouseMovement)

--////////////////////////////////////////////////////
-- SLIDER CONTROL
--////////////////////////////////////////////////////
local sliderDragging = false

local function setSlider(mouseX)
	local percent = math.clamp((mouseX - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
	knob.Position = UDim2.new(percent, 0, 0.5, 0)
	if currentTrack and currentTrack.Length > 0 then
		currentTrack.TimePosition = percent * currentTrack.Length
	end
end

slider.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		sliderDragging = true
		setSlider(input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		sliderDragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if sliderDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		setSlider(input.Position.X)
	end
end)

