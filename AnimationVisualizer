-- Animation ID Input Handler
local function tryLoadNewAnimation()
	local text = animIdBox.Text:gsub("%D", "")  -- Remove anything that's not a digit
	if text == "" then return end

	animIdBox.Text = text  -- Clean the box to show only numbers
	loadAnimation(text)
end

animIdBox.FocusLost:Connect(tryLoadNewAnimation)
animIdBox.ReturnPressedFromOnScreenKeyboard:Connect(tryLoadNewAnimation)

--////////////////////////////////////////////////////
-- UPDATE LOOP
--////////////////////////////////////////////////////
RunService.RenderStepped:Connect(function()
	-- Camera
	local target = root.Position + Vector3.new(0, 1, 0)
	local rotation = CFrame.Angles(0, math.rad(yaw), 0) * CFrame.Angles(math.rad(pitch), 0, 0)
	local offset = rotation:VectorToWorldSpace(Vector3.new(0, 0, zoom))
	camera.CFrame = CFrame.new(target + offset, target)

	-- Update slider
	if not sliderDragging and currentTrack and currentTrack.Length > 0 then
		knob.Position = UDim2.new(currentTrack.TimePosition / currentTrack.Length, 0, 0.5, 0)
	end

	-- Update time label
	if currentTrack and currentTrack.Length > 0 then
		timeLabel.Text = string.format("%.2fs / %.2fs", currentTrack.TimePosition, currentTrack.Length)
	else
		timeLabel.Text = "0.00s / 0.00s"
	end
end)
