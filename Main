--Maid
function cleanTask(oldtask: any)
	if typeof(oldtask) == "RBXScriptConnection" then
		oldtask:Disconnect()
	elseif typeof(oldtask) == "Instance" and oldtask:IsA("Tween") then
		oldtask:Pause()
		oldtask:Cancel()
		oldtask:Destroy()
	elseif typeof(oldtask) == "thread" then
		return coroutine.status(oldtask) == "suspended" and task.cancel(oldtask) or nil
	elseif oldtask.Destroy then
		oldtask:Destroy()
	end
end

local Maid = {}
Maid.__index = Maid

-- Adds new task and cleans old task if it exists
Maid.__newindex = function(self, index, newTask)
	local tasks = self.tasks
	local oldtask = tasks[index]
	if oldtask == newTask then
		return
	end

	tasks[index] = newTask

	if oldtask then
		cleanTask(oldtask)
	end
end

function Maid.new()
	return setmetatable({tasks = {}}, Maid)
end

function Maid:Add(task)
	local taskId = #self.tasks + 1
	self[taskId] = task

	return task, taskId
end

-- Cleans task and removes its reference from the task table
function Maid:Remove(taskId)
	local tasks = self.tasks
	local task = tasks[taskId]

	if task then
		cleanTask(task)
		tasks[taskId] = nil
	end
end

-- Cleans all tasks and empties the tasks table
function Maid:Clean()
	local tasks = self.tasks
	local index, _task = next(tasks)

	while _task ~= nil do
		tasks[index] = nil
		cleanTask(_task)
		index, _task = next(tasks)
	end
end

-- Store old instance properties

local Storage = {}
Storage.__index = Storage

function Storage.new()
	return setmetatable({}, Storage)
end

function Storage:Add(Identifier: any, Property: string, Value: any)
	if self[Identifier] then return end
	self[Identifier] = {Property, Value}
end

function Storage:Remove(Identifier: any)
	local attributes = self[Identifier]
	self[Identifier] = nil
	if attributes then
		return attributes[1], attributes[2]
	end
end

-- Instance wrap
function WrapInstance(instanceMaid, identifier: any, type: string, parent: Instance?)
	local maidInstance = instanceMaid[identifier]
	if maidInstance then
		return maidInstance
	end

	local newInstance = Instance.new(type, parent)
	instanceMaid[identifier] = newInstance
	local ac; ac = newInstance.AncestryChanged:Connect(function(_, parent)
		if not parent then
			instanceMaid:Remove(identifier)
			if ac then
				ac:Disconnect()
				ac = nil
			end
		end
	end)
	return newInstance
end

