-- MOBILITY
local noclipParts = Storage.new()
function UpdateNoclip()
	if not PlayerCharacter then return end

	for _, instance in ipairs(PlayerCharacter:GetChildren()) do

		if instance:IsA("BasePart") then
			noclipParts:Add(instance.Name, "CanCollide", instance.CanCollide)
			instance.CanCollide = false
		end
	end
end

local flyMaid = Maid.new()
function UpdateFly()
	local rootPart = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	local ForwardValue = UserInputService:IsKeyDown(Enum.KeyCode.W) and -1 or 0
	local BackwardValue = UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0
	local RightValue = UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0
	local LeftValue = UserInputService:IsKeyDown(Enum.KeyCode.A) and -1 or 0
	local UpValue = UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0

	local flyBodyVelocity = WrapInstance(flyMaid, "flyBodyVelocity", "BodyVelocity", rootPart)
	flyBodyVelocity.MaxForce = Vector3.new(9e9,9e9,9e9)
	local flyVelocity = camera.CFrame:VectorToWorldSpace(
		Vector3.new(
			LeftValue + RightValue,
			0,
			ForwardValue + BackwardValue
		)
			*
			Options.FlySpeed.Value
	) + Vector3.new(0, UpValue * Options.FlySpeed.Value,0)


	if flyVelocity == Vector3.zero then
		local pos = rootPart.Position
		rootPart.Anchored = true
	else
		rootPart.Anchored = false
	end
	flyBodyVelocity.Velocity = flyVelocity 
end

function UpdateSpeedHack()
	if Toggles.Fly.Value then
		return
	end

	local rootPart = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
	local hum = PlayerCharacter and PlayerCharacter:FindFirstChildOfClass("Humanoid")

	if not rootPart or not hum then
		return
	end

	rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity * Vector3.new(0, 1, 0)

	local Speed = Options.SpeedhackSpeed.Value
	local Direction = hum.MoveDirection

	if Direction.Magnitude <= 0.001 then
		return
	end

	rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + Direction.Unit * Speed
end

function UpdateInfiniteJump()
	if Toggles.Fly.Value then
		return
	end

	local rootPart = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")

	if not rootPart then 
		return
	end

	if not UserInputService:IsKeyDown(Enum.KeyCode.Space) then
		return
	end

	rootPart.AssemblyLinearVelocity = Vector3.new(rootPart.AssemblyLinearVelocity.X, Options.InfiniteJumpBoost.Value, rootPart.AssemblyLinearVelocity.Z)
end

function getHPColor(percent)
	percent = math.clamp(percent, 0, 100)
	local t = percent
	local hue = t * 0.33
	return Color3.fromHSV(hue, 1, 1)
end

function checkAlly(entity: Model): boolean
	local PlayerSchool = PlayerCharacter and PlayerCharacter:GetAttribute("School")
	local SquadID = PlayerCharacter and PlayerCharacter:GetAttribute("SquadID")

	local changed = false
	if PlayerSchool and PlayerSchool ~= "" then
		if PlayerSchool == entity:GetAttribute("School") then
			return true
		end
	end
	if not changed and SquadID and SquadID ~= "" then
		if SquadID == entity:GetAttribute("SquadID") then
			return true
		end
	end
	if entity:GetAttribute("MOB_behaviour") == "villager" then
		return true
	end
end

-- ESP

function RemoveEsp(esp)
	if not esp then return end
	if esp.Text then esp.Text:Remove() end
	if esp.HealthText then esp.HealthText:Remove() end
	if esp.DistanceText then esp.DistanceText:Remove() end
	if esp.Box then esp.Box:Remove() end
	if esp.HealthBar then esp.HealthBar:Remove() end
	if esp.HealthBarBg then esp.HealthBarBg:Remove() end
end

function updateEsp(entity: Instance, esp, args: {TextColor3: Color3})
	local camera = workspace.CurrentCamera
	if not entity then
		RemoveEsp(esp)
	end
	local rootPart = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
	if not rootPart then
		if esp.Box then esp.Box.Visible = false end
		if esp.HealthBar then esp.HealthBar.Visible = false end
		if esp.HealthBarBg then esp.HealthBarBg.Visible = false end
		if esp.Text then esp.Text.Visible = false end
		if esp.HealthText then esp.HealthText.Visible = false end
		if esp.DistanceText then esp.DistanceText.Visible = false end
		return
	end

	local humanoid = entity:FindFirstChildWhichIsA("Humanoid")
	local health = humanoid and humanoid.Health or 100
	local maxHealth = humanoid and humanoid.MaxHealth or 100
	local healthPct = math.clamp(health / maxHealth, 0, 1)
	local healthRounded = math.floor(health + 0.5)

	local topPos = rootPart.Position + Vector3.new(0, 3, 0)
	local bottomPos = rootPart.Position - Vector3.new(0, 3, 0)

	local topScreen, topOnScreen = camera:WorldToViewportPoint(topPos)
	local bottomScreen, bottomOnScreen = camera:WorldToViewportPoint(bottomPos)

	local onScreen = topOnScreen and bottomOnScreen
	if not onScreen then
		if esp.Box then esp.Box.Visible = false end
		if esp.HealthBar then esp.HealthBar.Visible = false end
		if esp.HealthBarBg then esp.HealthBarBg.Visible = false end
		if esp.Text then esp.Text.Visible = false end
		if esp.HealthText then esp.HealthText.Visible = false end
		if esp.DistanceText then esp.DistanceText.Visible = false end
		return
	end

	local TextColor3
	if args.TextColor3 then
		if checkAlly(entity) then
			TextColor3 = Color3.new(1-args.TextColor3.R, 1-args.TextColor3.G, 1-args.TextColor3.B)
		else
			TextColor3 = args.TextColor3
		end
	end

	-- Calculate distance
	local distance = (camera.CFrame.Position - rootPart.Position).Magnitude
	local distanceRounded = math.floor(distance + 0.5)

	local height = math.abs(topScreen.Y - bottomScreen.Y)
	local width = height * 0.6

	local x = topScreen.X - width / 2
	local y = topScreen.Y

	if esp.Box then
		esp.Box.Size = Vector2.new(width, height)
		esp.Box.Position = Vector2.new(x, y)
		esp.Box.Visible = true
		if args and TextColor3 then
			esp.Box.Color = TextColor3
		end
	end

	if esp.HealthBarBg then
		esp.HealthBarBg.Size = Vector2.new(4, height)
		esp.HealthBarBg.Position = Vector2.new(x - 6, y)
		esp.HealthBarBg.Visible = true
	end

	if esp.HealthBar then
		local barHeight = height * healthPct
		esp.HealthBar.Size = Vector2.new(4, barHeight)
		esp.HealthBar.Position = Vector2.new(x - 6, y + height - barHeight)
		esp.HealthBar.Visible = true
		esp.HealthBar.Color = getHPColor(healthPct)
	end

	if esp.Text then
		esp.Text.Position = Vector2.new(topScreen.X, topScreen.Y - 20)
		esp.Text.Visible = true
		if args and TextColor3 then
			esp.Text.Color = TextColor3
		end
	end

	if esp.HealthText then
		esp.HealthText.Text = healthRounded .. " / " .. math.floor(maxHealth)
		esp.HealthText.Position = Vector2.new(topScreen.X, bottomScreen.Y + 5)
		esp.HealthText.Visible = true
		if args and TextColor3 then
			esp.HealthText.Color = TextColor3
		end
	end

	if esp.DistanceText then
		esp.DistanceText.Text = distanceRounded .. " studs"
		esp.DistanceText.Position = Vector2.new(topScreen.X, bottomScreen.Y + 22)
		esp.DistanceText.Visible = true
		if args and TextColor3 then
			esp.DistanceText.Color = TextColor3
		end
	end
end

function createESP(entity: Instance, color: Color3, size: number)
	local esp = {}

	-- Name
	local text = Drawing.new("Text")
	text.Text = entity.Name
	text.Color = color
	text.Size = size
	text.Center = true
	text.Outline = true
	text.OutlineColor = Color3.new(0, 0, 0)
	text.Font = Drawing.Fonts.Plex
	text.Visible = false
	esp.Text = text

	-- Health Text
	local healthText = Drawing.new("Text")
	healthText.Text = "100 HP"
	healthText.Color = color
	healthText.Size = size - 2
	healthText.Center = true
	healthText.Outline = true
	healthText.OutlineColor = Color3.new(0, 0, 0)
	healthText.Font = Drawing.Fonts.Plex
	healthText.Visible = false
	esp.HealthText = healthText

	-- Distance Text
	local distanceText = Drawing.new("Text")
	distanceText.Text = "100 studs"
	distanceText.Color = color
	distanceText.Size = size - 4
	distanceText.Center = true
	distanceText.Outline = true
	distanceText.OutlineColor = Color3.new(0, 0, 0)
	distanceText.Font = Drawing.Fonts.Plex
	distanceText.Visible = false
	esp.DistanceText = distanceText

	-- Box
	local box = Drawing.new("Square")
	box.Color = color
	box.Thickness = 2
	box.Filled = false
	box.Transparency = 1
	box.Visible = false
	esp.Box = box

	-- Health Bar Background
	local bg = Drawing.new("Square")
	bg.Color = Color3.new(0, 0, 0)
	bg.Thickness = 1
	bg.Filled = true
	bg.Transparency = 0.7
	bg.Visible = false
	esp.HealthBarBg = bg

	-- Health Bar
	local bar = Drawing.new("Square")
	bar.Color = Color3.fromRGB(0, 255, 0)
	bar.Thickness = 1
	bar.Filled = true
	bar.Transparency = 1
	bar.Visible = false
	esp.HealthBar = bar

	return esp
end

local PlayerEsps = {}
local MobEsps = {}

function createPlayerEsp(player: Player, tbl)
	local character = player
	if Players:GetPlayerFromCharacter(player) then
		character = player.Character
	end
	if not character then return nil end
	local color = Color3.new(1, 1, 1)
	local size = 18
	local esp = createESP(character, color, size)
	esp.Text.Text = player.Name
	tbl[player] = esp
	return esp
end

local CacheEsps = {}
function addCacheEsp(model: Instance)
	if model.Name == "itemCacheModel" then
		local part = model:FindFirstChild("itemCache")
		if not part then return end

		local billboard = Instance.new("BillboardGui")
		billboard.Size = UDim2.new(0, 200, 0, 100)
		billboard.StudsOffset = Vector3.new(0, 3, 0)
		billboard.AlwaysOnTop = true
		billboard.Adornee = part
		billboard.Parent = part
		table.insert(CacheEsps, billboard)

		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1, 0, 1, 0)
		text.BackgroundTransparency = 1
		text.Text = "Item Cache"
		text.TextScaled = true
		text.TextColor3 = Color3.new(1,1,0)
		text.Parent = billboard
	end
end
-- esp end

function UpdateAttachToEntity(entity: Model)
	local root: BasePart? = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
	if not root then
		return true
	end

	if not entity then
		return
	end

	local EntityRootPart: BasePart? = entity:FindFirstChild("HumanoidRootPart") 
		or entity.PrimaryPart 
		or entity:FindFirstChildOfClass("BasePart")

	if not EntityRootPart then
		return
	end

	local EntityHumanoid: Humanoid? = entity:FindFirstChildOfClass("Humanoid")
	if not EntityHumanoid or EntityHumanoid.Health <= 0 then
		return
	end

	local Latitude = math.rad(Options.AttachLatitude.Value)
	local Longitude = math.rad(Options.AttachLongitude.Value)
	local Length = Options.AttachLength.Value

	local x = math.cos(Latitude) * math.cos(Longitude) * Length
	local y = math.sin(Latitude) * Length
	local z = math.cos(Latitude) * math.sin(Longitude) * Length


	local offsetPosition = (EntityRootPart.CFrame * CFrame.new(x, y, z)).Position
	root.CFrame = CFrame.lookAt(offsetPosition, EntityRootPart.Position)

	return true
end
function getClosestEntity(AllyAllowed: boolean?, PlayerAllowed: boolean?, MobsAllowed: boolean?): Model?
	local closestEnemy, closestDistance = nil, math.huge
	for _, obj in ipairs(workspace.Live:GetChildren()) do

		local IsPlayer = Players:GetPlayerFromCharacter(obj)

		if (not PlayerAllowed and IsPlayer) or obj == PlayerCharacter then
			continue
		end

		if not MobsAllowed and not IsPlayer then
			continue
		end

		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then

			if not AllyAllowed and checkAlly(obj) then
				continue
			end

			if obj.Humanoid.Health <= 0 then
				continue
			end
			local distance = (obj.HumanoidRootPart.Position - PlayerCharacter.HumanoidRootPart.Position).Magnitude
			if distance < closestDistance then
				closestEnemy = obj
				closestDistance = distance
			end
		end
	end
	return closestEnemy
end

