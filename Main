-- enables functions
local EnableFunctions = {
	NoClip = function()
		MainMaid.NoClipConn = RunService.RenderStepped:Connect(UpdateNoclip)
	end,
	Fly = function()
		MainMaid.FlyConn = RunService.RenderStepped:Connect(UpdateFly)	
	end,
	SpeedHack = function()
		MainMaid.SpeedHackConn = RunService.RenderStepped:Connect(UpdateSpeedHack)		
	end,
	InfiniteJump = function()
		MainMaid.InfiniteJumpConn = RunService.RenderStepped:Connect(UpdateInfiniteJump)		
	end,

	-- ESP
	PlayerEsp = function()
		for _, player in ipairs(Players:GetPlayers()) do
			if player == LocalPlayer then 
				continue
			end

			if not player.Character then
				continue
			end

			createPlayerEsp(player, PlayerEsps)
		end
		MainMaid.PlayerEspConn = RunService.RenderStepped:Connect(function()
			for player, esp in pairs(PlayerEsps) do
				if not esp then
					PlayerEsps[player] = nil
					continue
				end
				if not player.Character then
					RemoveEsp(esp)
					PlayerEsps[player] = nil
					continue
				end
				updateEsp(player.Character, esp, {
					TextColor3 = Options.PlayerEspColor.Value,
				})
			end
		end)
	end,
	MobEsp = function()

		local function checkMob(mob)
			if mob == PlayerCharacter then 
				return
			end

			if Players:GetPlayerFromCharacter(mob) then
				return
			end

			createPlayerEsp(mob, MobEsps)
		end

		for _, mob in ipairs(workspace.Live:GetChildren()) do
			checkMob(mob)
		end
		MainMaid.MobEspConn = RunService.RenderStepped:Connect(function()
			for player, esp in pairs(MobEsps) do
				if not esp then
					MobEsps[player] = nil
					continue
				end
				if not player then
					RemoveEsp(esp)
					MobEsps[player] = nil
					continue
				end
				updateEsp(player, esp, {
					TextColor3 = Options.MobEspColor.Value,
				})
			end
		end)

		MainMaid["MobAdded"] = workspace.Live.ChildAdded:Connect(checkMob)
	end,
	-- OTHER
	PlayerNotifier = function()
		for _, plr in game.Players:GetPlayers() do
			if plr ~= LocalPlayer then
				Library:Notify(`{plr.Name} has joined the game.`)
			end
		end
	end,
	TeleportDreamCube = function()

		if not workspace:FindFirstChild("Thrown") then
			return
		end
		MainMaid["TeleportDreamCube"] = workspace.Thrown.ChildAdded:Connect(function(part)
			if not part:IsA("BasePart") then return end
			if string.lower(part.Name):match("cub") then
				for _, player in ipairs(Players:GetPlayers()) do
					if PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart") then
						local root = PlayerCharacter.HumanoidRootPart

						root.CFrame = part.CFrame + Vector3.new(0, 3, 0)

						root.Anchored = true

						task.delay(1, function()
							if root then
								root.Anchored = false
							end
						end)
					end
				end
			end
		end)
	end,
	CacheEsp = function()
		for _, model in workspace.Thrown:GetChildren() do
			addCacheEsp(model)
		end
		MainMaid["CacheEsp"] = workspace.Thrown.ChildAdded:Connect(addCacheEsp)
	end,
	TrinketPickup = function()
		local root = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
		if not root then return end

		for _, obj in ipairs(workspace:GetChildren()) do
			if not Toggles.TrinketPickup.Value then
				break
			end
			if obj:IsA("BasePart") and obj.Name == "Loot" then
				root.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
				for i = 1, 3 do
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
					task.wait(0.05) 
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
				end

				if obj.Transparency >= 0.9 then
					obj:Destroy()
				end
			end
		end

		if workspace:FindFirstChild("LootFolder") then
			for _, obj in ipairs(workspace.LootFolder:GetChildren()) do
				if not Toggles.TrinketPickup.Value then
					break
				end
				if obj:IsA("BasePart") and obj.Name == "Loot" then
					root.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
					for i = 1, 3 do
						VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
						task.wait(0.05) 
						VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
					end

					if obj.Transparency >= 0.9 then
						obj:Destroy()
					end
				end
			end
		end

		if  workspace:FindFirstChild("THEMAP") then
			for _, obj in ipairs(workspace.THEMAP:GetChildren()) do
				if not Toggles.TrinketPickup.Value then
					break
				end
				if obj:IsA("BasePart") and obj.Name == "Loot" then
					root.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
					for i = 1, 3 do
						VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
						task.wait(0.05) 
						VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
					end

					if obj.Transparency >= 0.9 then
						obj:Destroy()
					end
				end
			end
		end
	end,
	AttachToEnemy = function()
		if not PlayerCharacter then
			return
		end

		local closestEnemy
		local StartAttaching: ()->()
		local function AttachToEnemy()
			MainMaid.AttachToEnemy = RunService.RenderStepped:Connect(function()
				local EnemyExisting = UpdateAttachToEntity(closestEnemy)
				if not EnemyExisting then
					StartAttaching()
				end
			end)
		end

		StartAttaching = function()
			MainMaid:Remove("AttachToEnemy")
			closestEnemy = getClosestEntity(Toggles.AttachToAllies.Value, Toggles.AttachToPlayers.Value, Toggles.AttachToMobs.Value)
			MainMaid.WaitingForAttach = task.spawn(function()
				while not closestEnemy do
					task.wait(1)
					closestEnemy = getClosestEntity(Toggles.AttachToAllies.Value, Toggles.AttachToPlayers.Value, Toggles.AttachToMobs.Value)
				end
				AttachToEnemy()
			end)

		end

		StartAttaching()
	end,
	LockOn = function()
		if not PlayerCharacter then
			return
		end

		local closestEnemy
		local StartAttaching: ()->()
		local function StartLockOn()
			MainMaid.LockOnConn = RunService.RenderStepped:Connect(function()
				local root = closestEnemy and closestEnemy:FindFirstChild("HumanoidRootPart")
				local hum = closestEnemy and closestEnemy:FindFirstChildOfClass("Humanoid")
				if not root or not hum or hum.Health <= 0 then
					StartAttaching()
				else
					local plrRoot = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
					if not plrRoot then
						return
					end

					local plrPos = plrRoot.Position
					local enemyPos = root.Position
					local distance = (Vector2.new(plrPos.X, plrPos.Z) - Vector2.new(enemyPos.X, enemyPos.Z)).Magnitude
					if distance <= Options.LockOnDistance.Value then
						return
					end
					UpdateCameraLookAt(root.Position)
				end
			end)
		end

		StartAttaching = function()
			MainMaid:Remove("LockOnConn")
			MainMaid.WaitingForEntity = task.spawn(function()
				closestEnemy = getEntityClosestToCamera(Toggles.AttachToAllies.Value, Toggles.AttachToPlayers.Value, Toggles.AttachToMobs.Value)
				while not closestEnemy do
					task.wait(1)
					closestEnemy = getEntityClosestToCamera(Toggles.AttachToAllies.Value, Toggles.AttachToPlayers.Value, Toggles.AttachToMobs.Value)
				end
				StartLockOn()
			end)
		end

		StartAttaching()
	end,
	AutoParry = function()
		StartAutoParry()
	end,
}

-- toggles functions to disable
local DisableFunctions = {
	NoClip = function()
		MainMaid:Remove("NoClipConn")
		for name, _ in pairs(noclipParts) do
			if not PlayerCharacter then return end
			local part = PlayerCharacter:FindFirstChild(name)
			local property, value = noclipParts:Remove(name) 
			if part then
				part[property] = value
			end
		end
	end,
	Fly = function()
		MainMaid:Remove("FlyConn")
		flyMaid:Remove("flyBodyVelocity")
		local hrp = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.Anchored = false
		end
	end,
	SpeedHack = function()
		MainMaid:Remove("SpeedHackConn")
	end,
	InfiniteJump = function()
		MainMaid:Remove("InfiniteJumpConn")
	end,

	-- ESP
	PlayerEsp = function()
		for i, esp in pairs(PlayerEsps) do
			RemoveEsp(esp)
			PlayerEsps[i] = nil
		end
		PlayerEsps = {}
		MainMaid:Remove("PlayerEspConn")
	end,
	MobEsp = function()
		for i, esp in pairs(MobEsps) do
			RemoveEsp(esp)
		end
		MobEsps = {}
		MainMaid:Remove("MobAdded")
		MainMaid:Remove("MobEspConn")
	end,
	TeleportDreamCube = function()
		MainMaid:Remove("TeleportDreamCube")
	end,
	CacheEsp = function()
		for _, cache in ipairs(CacheEsps) do
			if cache then
				cache:Destroy()
			end
			CacheEsps = {}
		end
		MainMaid:Remove("CacheEsp")
	end,
	AttachToEnemy = function()
		MainMaid:Remove("AttachToEnemy")
		MainMaid:Remove("AttachPosition")
		MainMaid:Remove("WaitingForAttach")

	end,
	LockOn = function()
		MainMaid:Remove("LockOnConn")
		MainMaid:Remove("WaitingForEntity")

	end,
	AutoParry = function()
		EndAutoParry()
	end,
}

-- CONNECTIONS
local PlayerAddedConnection = Players.PlayerAdded:Connect(function(player)
	if Toggles.PlayerNotifier.Value then
		Library:Notify(`{player.Name} has joined the game.`)
	end

	local CharacterAddedConnection = player.CharacterAdded:Connect(function(character)
		if Toggles.PlayerEsp.Value then
			if player ~= LocalPlayer then
				if not PlayerEsps[player] then
					createPlayerEsp(player, PlayerEsps)
				end
			end
		end
	end)

	local CharacterRemovingConnection = player.CharacterRemoving:Connect(function(character)
		if Toggles.PlayerEsp.Value then
			if PlayerEsps[player] then
				RemoveEsp(PlayerEsps[player])
				PlayerEsps[player] = nil
			end
		end
	end)

	MainMaid:Add(CharacterAddedConnection)
	MainMaid:Add(CharacterRemovingConnection)
end)
MainMaid:Add(PlayerAddedConnection)

-- Library stuff

function CreateToggle(Box: unknown, Name: string, Args: {Text: string?, Tooltip: string?, DisabledTooltip: string?, Default: boolean?, Disabled: boolean?, Risky: boolean?, Visible: boolean?}, NoKeyPicker: boolean?)
	local tgl = Box:AddToggle(Name, Args)
	if not NoKeyPicker then
		tgl:AddKeyPicker(Name, {
			Default = '',
			Text = Args["Text"],
			SyncToggleState = true
		})
	end
	local function toggle()
		if tgl.Value then
			EnableFunctions[Name]()
		else
			if DisableFunctions[Name] then
				DisableFunctions[Name]()
			end
		end
	end
	tgl:OnChanged(toggle)
end

