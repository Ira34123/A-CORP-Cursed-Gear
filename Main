ParryConfigs = isfile(CGFolder)
if ParryConfigs then
	ParryConfigs = HttpService:JSONDecode(readfile(CGFolder))

	if not ParryConfigs or not ParryConfigs["Groups"] or not ParryConfigs["IDToGroup"] then
		ParryConfigs = DefaultParryConfigs
		Library:Notify('Failed to read ap config file, using default config')
	else
		for groupName, group in pairs(DefaultParryConfigs.Groups) do
			if not ParryConfigs.Groups[groupName] then
				for animID, GroupID in pairs(DefaultParryConfigs.IDToGroup) do
					if GroupID == groupName then
						if not ParryConfigs.IDToGroup[animID] then
							ParryConfigs.IDToGroup[animID] = groupName
							ParryConfigs.Groups[groupName] = group
						end
					end
				end
			end
		end
	end
else
	ParryConfigs = DefaultParryConfigs
end

