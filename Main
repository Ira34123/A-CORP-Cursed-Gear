local function horizontalLookVector(root)
	local look = root.CFrame.LookVector
	look = Vector3.new(look.X, 0, look.Z).Unit	
	return look
end



local AutoParryMaid = Maid.new()

function HandleParry(entity)
	if not entity then return end

	AutoParryMaid[entity] = entity.Humanoid.Animator.AnimationPlayed:Connect(function(animationTrack)
		local id = string.match(animationTrack.Animation.AnimationId, "%d+")
		local AnimationConfig = ParryConfigs["Groups"][ParryConfigs.IDToGroup[id]]

		if not AnimationConfig then return end

		local MaxDistance = tonumber(AnimationConfig.Distance) or 0
		local MaxDistanceY = tonumber(AnimationConfig.DistanceY) or 0
		local Time = tonumber(AnimationConfig.WhenToParry) or 0
		local HasToFace = tonumber(AnimationConfig.FacingDirection) or 0
		local TimePerStud = tonumber(AnimationConfig.TimePerStud) or 0
		local TimeEnd = tonumber(AnimationConfig.TimeEnd) or 1
		local MinimumDistance = tonumber(AnimationConfig.TimeToDistanceDelay) or 0
		local ParryDelay = Options.ParryDelay.Value or 0

		local EntityRootPart = entity:FindFirstChild("HumanoidRootPart")
		local root = PlayerCharacter and PlayerCharacter:FindFirstChild("HumanoidRootPart")

		if not (EntityRootPart and root) then return end
		
		local initialDist = (root.Position - EntityRootPart.Position).Magnitude

		local initialDistXZ =
			(Vector2.new(root.Position.X, root.Position.Z)
				- Vector2.new(EntityRootPart.Position.X, EntityRootPart.Position.Z)).Magnitude

		local initialDistY = math.abs(root.Position.Y - EntityRootPart.Position.Y)

		if initialDistXZ / 3 > MaxDistance or initialDistY / 3 > MaxDistanceY then return end

		local Ping = Toggles.PingAdjust.Value and LocalPlayer:GetNetworkPing() or 0
		local ParryTime = Time

		local conn
		conn = RunService.RenderStepped:Connect(function()
			if not animationTrack.IsPlaying then
				conn:Disconnect()
				return
			end

			local progress = animationTrack.TimePosition
			if progress >= TimeEnd then
				conn:Disconnect()
				return
			end

			local rootPos = root.Position
			local entityPos = EntityRootPart.Position

			local distanceXZ =
				(Vector2.new(rootPos.X, rootPos.Z)
					- Vector2.new(entityPos.X, entityPos.Z)).Magnitude

			local distanceY = math.abs(rootPos.Y - entityPos.Y)

			if distanceXZ > MaxDistance or distanceY > MaxDistanceY then return end

			local ExtraTime = 0
			if initialDist > MinimumDistance then
				ExtraTime = (initialDist - MinimumDistance) * TimePerStud
			end
			
			if Toggles.PingAdjust.Value then
				Ping = LocalPlayer:GetNetworkPing()
			end
			
			local Speed = animationTrack.Speed

			if progress >= ParryTime - Ping*Speed - ParryDelay*Speed + ExtraTime then
				if HasToFace ~= 0 then
					local toPlayer = (rootPos - entityPos).Unit
					local enemyLook = horizontalLookVector(EntityRootPart)
					local alignment = enemyLook:Dot(toPlayer)

					if HasToFace > alignment then return end
				end

				task.spawn(function()
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
					task.wait(0.05)
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
				end)
			end
		end)

		local StoppedConn
		local EndedConn
		EndedConn = animationTrack.Ended:Connect(function()
			if conn then conn:Disconnect() end
			if StoppedConn then StoppedConn:Disconnect() end
			if EndedConn then EndedConn:Disconnect() end
		end)
		StoppedConn = animationTrack.Stopped:Connect(function()
			if conn then conn:Disconnect() end
			if EndedConn then EndedConn:Disconnect() end
			if StoppedConn then StoppedConn:Disconnect() end
		end)

		AutoParryMaid:Add(conn)
		AutoParryMaid:Add(StoppedConn)
		AutoParryMaid:Add(EndedConn)
	end)
end

function StartAutoParry()
	for _, entity in ipairs(workspace.Live:GetChildren()) do
		if entity:FindFirstChild("Humanoid") and entity.Humanoid:FindFirstChild("Animator") and entity ~= PlayerCharacter then
			if entity.Humanoid.Health > 0 then
				HandleParry(entity)
			end
		end
	end

	AutoParryMaid.AutoParryChildAdded = workspace.Live.ChildAdded:Connect(function(entity)
		if entity:FindFirstChild("Humanoid") and entity.Humanoid:FindFirstChild("Animator") and entity ~= PlayerCharacter then
			if entity.Humanoid.Health > 0 then
				HandleParry(entity)
			end
		else
			if entity ~= PlayerCharacter then
				if entity:WaitForChild("Humanoid"):WaitForChild("Animator") then
					HandleParry(entity)
				end
			end
		end
	end)
end

function EndAutoParry()
	AutoParryMaid:Clean()
end

function FunctionSetApConfig(Group: string, Ids: string, WhenToParry: number, Distance: number, DistanceY: number, FacingDirection: number, TimePerStud: number, TimeEnd: number, TimeToDistanceDelay: number)
	ParryConfigs.Groups[Group] = {
		WhenToParry = WhenToParry,
		Distance = Distance,
		DistanceY = DistanceY,
		FacingDirection = FacingDirection,
		TimePerStud = TimePerStud,
		TimeEnd = TimeEnd,
		TimeToDistanceDelay = TimeToDistanceDelay,
	}

	local ids = Ids:split(",")
	for _, id in ipairs(ids) do
		ParryConfigs.IDToGroup[id] = Group
	end

	local EncodedConfigs = HttpService:JSONEncode(ParryConfigs)

	writefile(CGFolder, EncodedConfigs)		
	Options.ImportConfigs:SetValue(EncodedConfigs)
end

function DeleteApConfig(Group: string)
	if not Group or not ParryConfigs.Groups[Group] then
		return
	end
	ParryConfigs.Groups[Group] = nil
	for id, group in pairs(ParryConfigs.IDToGroup) do
		if group == Group then
			ParryConfigs.IDToGroup[id] = nil
		end
	end
	local EncodedConfigs = HttpService:JSONEncode(ParryConfigs)

	writefile(CGFolder, EncodedConfigs)		
	Options.ImportConfigs:SetValue(EncodedConfigs)
end

function getValues(Inputs)
	local values = {}
	for key, value in ipairs(Inputs) do
		if Options[value] then
			table.insert(values, Options[value].Value)
		end
	end
	return unpack(values)
end

