CreateToggle(RightGroupBox, "PlayerNotifier", {Text = "Notify player join"}, true)
CreateToggle(RightGroupBox, "TeleportDreamCube", {Text = "TP Dream Cubes", Tooltip = "Teleports to all the cubes in the dream world"}, true)
CreateToggle(RightGroupBox, "TrinketPickup", {Text = "Pickup trinkets"}, true)

RightGroupBox:AddButton({
	Text = "Teleport to cache",
	Callback = function()
		local folder = workspace.Thrown
		local player = game.Players.LocalPlayer
		local character = player.Character or player.CharacterAdded:Wait()
		local hrp = character:WaitForChild("HumanoidRootPart")

		local teleported = false

		local function handleModel(model)
			if teleported then return end
			if not model then return end

			local part = model:FindFirstChild("itemCache")
			if not part then return end

			hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
			teleported = true
		end

		handleModel(folder:FindFirstChild("itemCacheModel"))
		task.wait(0.2)
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.X, false, game)
		task.wait(0.05) 
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.X, false, game)
	end,
})

Library:OnUnload(function()
	for _, func in pairs(DisableFunctions) do
		func()
	end
	Library.Unloaded = true
	getgenv().CGLibraryLoadedYay = false
end)

-- UI Settings
local MenuGroup = Tabs['UI Settings']:AddLeftGroupbox('Menu')

MenuGroup:AddToggle("KeybindMenuOpen", { Default = Library.KeybindFrame.Visible, Text = "Open Keybind Menu", Callback = function(value) Library.KeybindFrame.Visible = value end})
MenuGroup:AddToggle("ShowCustomCursor", {Text = "Custom Cursor", Default = true, Callback = function(Value) Library.ShowCustomCursor = Value end})
MenuGroup:AddDivider()
MenuGroup:AddLabel("Menu bind"):AddKeyPicker("MenuKeybind", { Default = "RightShift", NoUI = true, Text = "Menu keybind" })
MenuGroup:AddButton("Unload", function() Library:Unload() end)

Library.ToggleKeybind = Options.MenuKeybind 

ThemeManager:SetLibrary(Library)
SaveManager:SetLibrary(Library)

-- Ignore keys that are used by ThemeManager.
-- (we dont want configs to save themes, do we?)
SaveManager:IgnoreThemeSettings()

SaveManager:SetIgnoreIndexes({ 'MenuKeybind' })

ThemeManager:SetFolder('A-CORP/Cursed-Gear/Themes')
SaveManager:SetFolder('A-CORP/Cursed-Gear')


SaveManager:BuildConfigSection(Tabs['UI Settings'])

ThemeManager:ApplyToTab(Tabs['UI Settings'])


SaveManager:LoadAutoloadConfig()

getgenv().CGLibraryLoadedYay = true
