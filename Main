	local MapStuff = workspace:WaitForChild("MapStuff")
	if not MapStuff then 
		return
	end
	local Map = MapStuff:WaitForChild("Map")
	if not Map then
		return
	end
	local Spawns = Map:WaitForChild("Spawns")
	if not Spawns then
		return
	end
	

	for _, obj in ipairs(Spawns:GetChildren()) do
		if obj:IsA("BasePart") and obj.Name == "Exit" then
			for _, text in ipairs(obj:GetDescendants()) do
				if text:IsA("TextLabel") then
					exitParts[text.Text] = obj
					break	
				end
			end
		end
	end
	return exitParts
end

function getEntityClosestToCamera(AllyAllowed: boolean?, MobAllowed: boolean?)
	local camera = workspace.CurrentCamera

	local closestAngle, closestDistance = 0, 5000
	local closestEntity = nil
	for _, obj in ipairs(workspace.Live:GetChildren()) do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
			if obj == PlayerCharacter then
				continue
			end
			if not AllyAllowed and checkAlly(obj) then
				continue
			end
			if not MobAllowed and not Players:GetPlayerFromCharacter(obj) then
				continue
			end
			local root = obj.HumanoidRootPart
			local direction = (root.Position - camera.CFrame.Position).Unit
			local angle = camera.CFrame.LookVector:Dot(direction)
			local distance = (root.Position - camera.CFrame.Position).Magnitude
			if angle > closestAngle and distance < closestDistance then
				closestEntity = obj
				closestAngle = angle
				closestDistance = distance
			end
		end
	end
	return closestEntity
end

function UpdateCameraLookAt(lookAt: Vector3)
	local camera = workspace.CurrentCamera
	camera.CFrame = CFrame.lookAt(camera.CFrame.Position, lookAt)
end

