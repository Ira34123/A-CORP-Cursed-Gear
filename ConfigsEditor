		-- State
		local currentGroup = nil
		local groupButtons = {}

		local function refreshGroupList(filter)
			for _, btn in ipairs(groupButtons) do btn:Destroy() end
			groupButtons = {}

			local groups = {}
			for name in pairs(ParryConfigs.Groups) do
				table.insert(groups, name)
			end
			table.sort(groups)

			local filtered = {}
			for _, name in ipairs(groups) do
				if not filter or filter == "" or string.find(string.lower(name), string.lower(filter)) then
					table.insert(filtered, name)
				end
			end

			groupScroll.CanvasSize = UDim2.new(0, 0, 0, #filtered * 50)

			for _, groupName in ipairs(filtered) do
				local btn = Instance.new("TextButton")
				btn.Size = UDim2.new(1, 0, 0, 42)
				btn.BackgroundColor3 = Color3.fromRGB(48, 48, 48)
				btn.Text = groupName
				btn.TextColor3 = Color3.fromRGB(255, 255, 255)
				btn.TextScaled = true
				btn.Font = Enum.Font.GothamSemibold
				btn.Parent = groupScroll

				local btnCorner = Instance.new("UICorner")
				btnCorner.CornerRadius = UDim.new(0, 8)
				btnCorner.Parent = btn

				btn.MouseButton1Click:Connect(function()
					currentGroup = groupName
					loadGroup(groupName)
				end)

				table.insert(groupButtons, btn)
			end
		end

		function loadGroup(groupName)
			currentGroup = groupName
			editorFrame.Visible = true
			editorTitle.Text = "Editing: " .. groupName

			local data = ParryConfigs.Groups[groupName]
			if not data then return end

			groupNameInput.Text = groupName

			-- Collect IDs
			local ids = {}
			for id, g in pairs(ParryConfigs.IDToGroup) do
				if g == groupName then
					table.insert(ids, id)
				end
			end
			table.sort(ids)
			idsInput.Text = table.concat(ids, ",")

			whenToParryInput.Text     = tostring(data.WhenToParry or 0)
			distanceInput.Text        = tostring(data.Distance or 0)
			distanceYInput.Text       = tostring(data.DistanceY or 0)
			facingDirectionInput.Text = tostring(data.FacingDirection or 0)
			timePerStudInput.Text     = tostring(data.TimePerStud or 0)
			timeEndInput.Text         = tostring(data.TimeEnd or 0)
			timeToDistanceDelayInput.Text = tostring(data.TimeToDistanceDelay or 0)
		end

		local function saveCurrent()
			if not currentGroup then return end

			local newName = groupNameInput.Text:match("^%s*(.-)%s*$")
			if newName == "" then
				-- You can add a warning here later
				return
			end

			-- === BETTER ID PARSING ===
			local idsStr = idsInput.Text or ""


			if idsStr == "" then
				return
			end

			local function n(txt) return tonumber(txt) or 0 end

			-- Handle rename
			local oldName = currentGroup
			if newName ~= oldName then
				if ParryConfigs.Groups[newName] then
					-- Optional: show "A group with this name already exists!"
					return
				end

				DeleteApConfig(oldName)
				currentGroup = newName
			else
				-- Same group name → clear ALL old IDs first
				for id, groupName in pairs(ParryConfigs.IDToGroup) do
					if groupName == oldName then
						ParryConfigs.IDToGroup[id] = nil
					end
				end
			end

			-- Now save with the properly parsed ID list
			FunctionSetApConfig(
				newName,
				idsStr,        -- Pass clean comma-separated string
				n(whenToParryInput.Text),
				n(distanceInput.Text),
				n(distanceYInput.Text),
				n(facingDirectionInput.Text),
				n(timePerStudInput.Text),
				n(timeEndInput.Text),
				n(timeToDistanceDelayInput.Text)
			)

			refreshGroupList(searchBox.Text)
			loadGroup(newName)   -- Refresh the editor so you see the correct IDs
		end
		local function deleteCurrent()
			if not currentGroup then return end
			DeleteApConfig(currentGroup)
			currentGroup = nil
			editorFrame.Visible = false
			refreshGroupList(searchBox.Text)
		end

